{
  "name": "kokonoepc",
  "displayName": "KokonoePC Support",
  "description": "KokonoePC Assembly VS Code Support",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "kokonoepc",
